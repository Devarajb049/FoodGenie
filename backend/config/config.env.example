# Port on which the backend server will run
PORT=8080

# Environment mode: DEVELOPMENT or PRODUCTION
NODE_ENV=PRODUCTION

# MongoDB Connection String (MongoDB Atlas URI in production)
DB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/foodgenie?retryWrites=true&w=majority

# JWT Configurations for Authentication
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE
JWT_EXPIRES=7d
JWT_EXPIRES_TIME=7

# Frontend Application URL (for CORS allowance and redirects)
FRONTEND_URL=https://your-frontend-vercel-domain.vercel.app

# Stripe Payments API Configurations
STRIPE_API_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Groq Cloud API Key for AI Integration
GROQ_API_KEY=gsk_your_groq_api_key

# Cloudinary Configs for Image Uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET_KEY=your_cloudinary_api_secret_key

# Mailer Configs for Reset Password & Notifications
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USERNAME=your_smtp_username
EMAIL_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@foodgenie.com
